envío promedio por orden (una orden puede tener varios ítems)\n","freight = items.groupby('order_id')['freight_value'].mean().reset_index()\n","\n","# === 3. UNIMOS LOS DATASETS POR order_id ===\n","df = payments.merge(orders[['order_id', 'shipping_time_days']], on='order_id', how='left')\n","df = df.merge(freight, on='order_id', how='left')\n","\n","# Quitamos valores nulos y extremos (tiempos negativos o muy altos)\n","df = df[(df['shipping_time_days'] > 0) & (df['shipping_time_days'] < 60)]\n","\n","# === 4. ANÁLISIS VISUAL ===\n","\n","sns.set(style=\"whitegrid\")\n","\n","# A. Relación entre cuotas y tiempo de envío\n","plt.figure(figsize=(10, 5))\n","sns.boxplot(x='payment_installments', y='shipping_time_days', data=df[df['payment_installments'] <= 10])\n","plt.title(\"Cuotas vs Tiempo de Envío (días)\")\n","plt.xlabel(\"Cuotas\")\n","plt.ylabel(\"Días de envío\")\n","plt.show()\n","\n","# B. Relación entre cuotas y coste de envío\n","plt.figure(figsize=(10, 5))\n","sns.boxplot(x='payment_installments', y='freight_value', data=df[df['payment_installments'] <= 10])\n","plt.title(\"Cuotas vs Costo de Envío\")\n","plt.xlabel(\"Cuotas\")\n","plt.ylabel(\"Costo de envío (freight_value)\")\n","plt.show()\n","\n","# === 5. CORRELACIÓN DE SPEARMAN ===\n","# (No asumimos relación lineal, por eso usamos Spearman)\n","\n","corr_days, p_days = spearmanr(df['payment_installments'], df['shipping_time_days'])\n","corr_cost, p_cost = spearmanr(df['payment_installments'], df['freight_value'])\n","\n","print(f\"📈 Correlación Cuotas - Tiempo de envío: ρ = {corr_days:.2f} (p = {p_days:.4f})\")\n","print(f\"📈 Correlación Cuotas - Costo de envío: ρ = {corr_cost:.2f} (p = {p_cost:.4f})\")\n","\n","# === 6. INTERPRETACIÓN ===\n","if p_days < 0.05:\n","    print(\"✅ Hay evidencia de relación entre cuotas y tiempo de envío.\")\n","else:\n","    print(\"❌ No hay relación estadísticamente significativa entre cuotas y tiempo de envío.\")\n","\n","if p_cost < 0.05:\n","    print(\"✅ Hay evidencia de relación entre cuotas y costo de envío.\")\n","else:\n","    print(\"❌ No hay relación estadísticamente significativa entre cuotas y costo de envío.\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":1000},"id":"OJVAgTebRZt4","executionInfo":{"status":"ok","timestamp":1750371722878,"user_tz":-120,"elapsed":4043,"user":{"displayName":"Marta Gutiérrez Maestre","userId":"09353946026143061627"}},"outputId":"e549ac70-961c-4f98-f709-5ec9dbdbcd13"},"execution_count":27,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x500 with 1 Axes>"],"image/png":"\n"},"metadata":{}},{"output_type":"stream","name":"stdout","text":["📈 Correlación Cuotas - Tiempo de envío: ρ = 0.08 (p = 0.0000)\n","📈 Correlación Cuotas - Costo de envío: ρ = 0.21 (p = 0.0000)\n","✅ Hay evidencia de relación entre cuotas y tiempo de envío.\n","✅ Hay evidencia de relación entre cuotas y costo de envío.\n"]}]},{"cell_type":"markdown","source":["## \"Al pagar en cuotas, los clientes tienden a comprar productos de mayor valor y de categorías específicas como electrónica, muebles o artículos para el hogar.\""],"metadata":{"id":"ic6XpkDvTcLt"}},{"cell_type":"code","source":["import pandas as pd\n","import seaborn as sns\n","import matplotlib.pyplot as plt\n","\n","# === 1. CARGA DE DATOS ===\n","payments = pd.read_csv(\"olist_order_payments_dataset.csv\")\n","items = pd.read_csv(\"olist_order_items_dataset.csv\")\n","products = pd.read_csv(\"olist_products_dataset.csv\")\n","\n","# === 2. UNIÓN DE DATASETS ===\n","# Juntamos pagos + items + productos\n","df = payments.merge(items[['order_id', 'product_id']], on='order_id', how='left')\n","df = df.merge(products[['product_id', 'product_category_name']], on='product_id', how='left')\n","\n","# === 3. CLASIFICACIÓN DE MÉTODO DE PAGO ===\n","df['payment_type'] = df['payment_installments'].apply(lambda x: 'contado' if x == 1 else 'cuotas')\n","\n","# === 4. AGRUPACIÓN: PRODUCTOS MÁS VENDIDOS POR TIPO DE PAGO ===\n","categoria_por_pago = (\n","    df.groupby(['payment_type', 'product_category_name'])\n","    .size()\n","    .reset_index(name='total_compras')\n",")\n","\n","# Obtenemos el top 10 de cada tipo de pago\n","top_categorias = (\n","    categoria_por_pago.sort_values(['payment_type', 'total_compras'], ascending=[True, False])\n","    .groupby('payment_type')\n","    .head(10)\n",")\n","\n","# === 5. VISUALIZACIÓN ===\n","plt.figure(figsize=(12, 6))\n","sns.barplot(\n","    data=top_categorias,\n","    x='total_compras',\n","    y='product_category_name',\n","    hue='payment_type'\n",")\n","plt.title(\"Top 10 categorías más compradas según tipo de pago\")\n","plt.xlabel(\"Cantidad de productos vendidos\")\n","plt.ylabel(\"Categoría de producto\")\n","plt.legend(title=\"Tipo de pago\")\n","plt.tight_layout()\n","plt.show()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":600},"id":"lOk_SB6ETjro","executionInfo":{"status":"ok","timestamp":1750372077144,"user_tz":-120,"elapsed":2655,"user":{"displayName":"Marta Gutiérrez Maestre","userId":"09353946026143061627"}},"outputId":"0c87d64f-dfec-4854-99eb-edab8512b5d2"},"execution_count":29,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1200x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]}]}